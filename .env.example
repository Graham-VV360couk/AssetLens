# AssetLens Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assetlens
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ============================================================================
# Redis Configuration (Caching Layer)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600
REDIS_DB=0

# ============================================================================
# Licensed Property Data Feed API
# ============================================================================
# Searchland API (Primary Provider - Rightmove, Zoopla, OnTheMarket)
SEARCHLAND_API_KEY=your_searchland_api_key_here
SEARCHLAND_BASE_URL=https://api.searchland.co.uk
SEARCHLAND_API_VERSION=v1

# PropertyData API (Alternative Provider)
PROPERTYDATA_API_KEY=your_propertydata_api_key_here
PROPERTYDATA_BASE_URL=https://api.propertydata.co.uk

# ============================================================================
# EPC (Energy Performance Certificate) API
# Register at https://epc.opendatacommunities.org/ — free account required.
# Used as fallback when certificate is not in the local bulk dataset.
# ============================================================================
EPC_API_EMAIL=your_email@example.com
EPC_API_KEY=your_epc_api_key_here

# Data Feed Settings
FEED_SYNC_FULL_ENABLED=true
FEED_SYNC_INCREMENTAL_ENABLED=true
FEED_BATCH_SIZE=1000
FEED_RATE_LIMIT_REQUESTS=100
FEED_RATE_LIMIT_PERIOD=60

# ============================================================================
# Email Configuration (SMTP for Daily Alerts)
# ============================================================================
# SendGrid Example (recommended)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=alerts@assetlens.example.com
SMTP_FROM_NAME=AssetLens Alerts

# Alert Configuration
ALERT_EMAIL=your_email@example.com
ALERT_THRESHOLD_SCORE=70
ALERT_SEND_TIME=06:00
ALERT_MAX_PROPERTIES=20

# ============================================================================
# Application Settings
# ============================================================================
# Environment
APP_ENV=development
DEBUG=true

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# Data Collection Settings
# ============================================================================
# Scraping Configuration
SCRAPER_USER_AGENT=AssetLens/1.0 (+https://assetlens.example.com)
SCRAPER_RATE_LIMIT_DELAY=2
SCRAPER_CONCURRENT_REQUESTS=8
SCRAPER_DOWNLOAD_TIMEOUT=30
SCRAPER_RETRY_TIMES=3

# Proxy Configuration (Optional - for production scraping)
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ============================================================================
# Machine Learning Configuration
# ============================================================================
ML_MODEL_PATH=backend/ml/models/valuation_model.pkl
ML_MODEL_RETRAIN_FREQUENCY=monthly
ML_MIN_TRAINING_SAMPLES=1000
ML_TEST_SIZE=0.2
ML_RANDOM_STATE=42

# ============================================================================
# Data Retention & Archival
# ============================================================================
# Property archival settings
ARCHIVE_AFTER_DAYS=180
REVIEWED_SUPPRESS_DAYS=180
SALES_HISTORY_YEARS=10
CLEANUP_FREQUENCY=weekly

# ============================================================================
# Land Registry Configuration
# ============================================================================
LAND_REGISTRY_DATA_URL=https://www.gov.uk/government/statistical-data-sets/price-paid-data-downloads
LAND_REGISTRY_YEARS=10
LAND_REGISTRY_BATCH_SIZE=5000

# ============================================================================
# Performance & Optimization
# ============================================================================
# Query Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# Background Jobs
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================================================
# Monitoring & Logging
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/assetlens.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Sentry Error Tracking (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# Security
# ============================================================================
# API Security
SECRET_KEY=your_random_secret_key_here_change_in_production
API_KEY_HEADER=X-API-Key
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_EMAIL_ALERTS=true
FEATURE_ML_VALUATION=true
FEATURE_HMO_ANALYSIS=true
FEATURE_AUCTION_SCRAPING=true
FEATURE_RENTAL_SCRAPING=true
